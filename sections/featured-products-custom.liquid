{{ 'section-featured-products-custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-featured-products.js' | asset_url }}" defer="defer"></script>

<div class="page-width">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="featured-products-custom">
        {% for block in section.blocks %}
          {% assign product = block.settings.product %}

          {% if product != blank %}
            {% assign current_variant = product.selected_or_first_available_variant %}
            {% assign is_on_sale = false %}

            {% if current_variant.compare_at_price > current_variant.price %}
              {% assign is_on_sale = true %}
            {% endif %}

            <div class="featured-products-custom-card" {{ block.shopify_attributes }}>
                {% if product.featured_image %}
                  <div class="featured-products-custom-card__media">
                    {% if section.settings.show_sale_badge and is_on_sale %}
                      <span class="featured-products-custom__badge">Sale</span>
                    {% endif %}

                    {{
                      product.featured_image
                      | image_url: width: 300
                      | image_tag: loading: 'lazy', alt: product.title
                    }}
                  </div>
                {% endif %}

                <h3>{{ product.title }}</h3>

                {% if is_on_sale %}
                  <p>
                    <span class="featured-products-custom__price featured-products-custom__price--sale">
                      {{ current_variant.price | money }}
                    </span>
                    <s class="featured-products-custom__compare-price">
                      {{ current_variant.compare_at_price | money }}
                    </s>
                  </p>
                {% else %}
                  <p>{{ current_variant.price | money }}</p>
                {% endif %}

                <button
                  type="button"
                  class="button featured-products-custom__add-to-cart"
                  data-variant-id="{{ current_variant.id }}"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  {% if current_variant.available %}
                    Add to cart
                  {% else %}
                    Sold out
                  {% endif %}
                </button>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p>Add product blocks in the theme editor.</p>
    {% endif %}
</div>

{% schema %}
  {
    "name": "Custom Featured Products",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Featured products"
      },
      {
        "type": "checkbox",
        "id": "show_sale_badge",
        "label": "Show sale badge",
        "default": true
      }
    ],
    "blocks": [
      {
        "type": "product",
        "name": "Product",
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Product"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Custom Featured Products"
      }
    ]
  }
{% endschema %}
